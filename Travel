<!-- TRAVEL HUB -->
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TravelForce - Travel Hub</title>
<style>
body{margin:0;font-family:Arial;background:#0a1f2b;color:white;}
header{background:#111;padding:15px;text-align:center;font-size:28px;}
nav{display:flex;justify-content:space-around;background:#222;padding:10px;position:sticky;top:60px;}
nav select, nav button{padding:8px;margin:0 5px;cursor:pointer;}
.section{display:none;padding:20px;}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:15px;margin-top:15px;}
.card{background:#1c2a38;padding:15px;border-radius:10px;cursor:pointer;transition:0.3s;}
.card:hover{transform:scale(1.05);background:#2a3d4f;}
.aiButton{position:fixed;bottom:20px;right:20px;border-radius:50%;width:60px;height:60px;background:#00eaff;color:black;font-size:26px;border:none;cursor:pointer;}
.aiWindow{position:fixed;bottom:90px;right:20px;background:#111;padding:15px;width:300px;display:none;border-radius:10px;}
</style>
</head>
<body>
<header>✈️ TravelForce</header>
<nav>
<select id="themeSelect" onchange="changeTheme(this.value)">
<option value="dark">Dark</option>
<option value="light">Light</option>
<option value="blue">Blue</option>
</select>
<button onclick="openSection('home')">Home</button>
<button onclick="openSection('destinations')">Destinations</button>
<button onclick="openSection('deals')">Deals</button>
<button onclick="openSection('guides')">Guides</button>
</nav>

<div id="home" class="section" style="display:block">
<h2>Welcome to TravelForce</h2>
<p>Discover destinations, find travel deals, and explore guides!</p>
<input id="search" placeholder="Search destinations or deals">
<button onclick="searchWeb()">Search</button>
</div>

<div id="destinations" class="section">
<h2>Popular Destinations</h2>
<div class="grid">
<div class="card" onclick="openSite('https://www.lonelyplanet.com/')">Lonely Planet</div>
<div class="card" onclick="openSite('https://www.tripadvisor.com/')">TripAdvisor</div>
<div class="card" onclick="openSite('https://www.booking.com/')">Booking.com</div>
</div>
</div>

<div id="deals" class="section">
<h2>Travel Deals</h2>
<div class="grid">
<div class="card" onclick="openSite('https://www.kayak.com/deals')">Kayak Deals</div>
<div class="card" onclick="openSite('https://www.expedia.com/deals')">Expedia Deals</div>
</div>
</div>

<div id="guides" class="section">
<h2>Travel Guides</h2>
<div class="grid">
<div class="card" onclick="openSite('https://www.nationalgeographic.com/travel/')">National Geographic</div>
<div class="card" onclick="openSite('https://www.travelandleisure.com/')">Travel + Leisure</div>
</div>
</div>

<div class="aiWindow" id="aiWindow">
<textarea id="aiInput" placeholder="Ask AI for travel tips"></textarea>
<button onclick="aiAnswer()">Ask</button>
<div id="aiOutput"></div>
</div>
<button class="aiButton" onclick="toggleAI()">🤖</button>

<script>
function openSection(id){document.querySelectorAll(".section").forEach(s=>s.style.display="none");document.getElementById(id).style.display="block";}
function openSite(url){window.open(url);}
function searchWeb(){let q=document.getElementById("search").value;window.open("https://www.google.com/search?q="+q);}
function toggleAI(){let w=document.getElementById("aiWindow");w.style.display=w.style.display=="block"?"none":"block";}
function aiAnswer(){let q=document.getElementById("aiInput").value;let out="I am a demo AI for travel."; if(q.toLowerCase().includes("cheap")) out="Check Expedia, Kayak, or Booking.com for cheap deals!";document.getElementById("aiOutput").innerText=out;}
function changeTheme(t){if(t=='dark'){document.body.style.background='#0a1f2b';document.body.style.color='white';}if(t=='light'){document.body.style.background='#eee';document.body.style.color='black';}if(t=='blue'){document.body.style.background='#0b3a60';document.body.style.color='white';}}
</script>
</body>
</html>
