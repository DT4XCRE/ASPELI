<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UpgradedForce Ultimate Hub vImages</title>
<style>
body{margin:0;font-family:Arial;background:#070b18;color:white;transition:0.3s;}
header{background:#111;color:white;padding:15px;text-align:center;font-size:28px;position:sticky;top:0;z-index:100;}
.topBanner{background:#ff6600;color:black;padding:15px;text-align:center;font-size:22px;cursor:pointer;}
.topBanner:hover{background:#ff8533;}
nav{display:flex;flex-wrap:wrap;justify-content:space-around;background:#222;padding:10px;position:sticky;top:60px;z-index:99;}
nav select, nav button{padding:8px;margin:0 5px;cursor:pointer;}
.section{display:none;padding:20px;}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:15px;margin-top:15px;}
.card{background:#1c2030;padding:15px;border-radius:10px;text-align:center;cursor:pointer;transition:0.3s;}
.card:hover{transform:scale(1.05);background:#2a2e42;}
.card img{width:100%;border-radius:10px;}
input,textarea{width:95%;padding:8px;margin:5px;}
.aiButton{position:fixed;bottom:20px;right:20px;width:60px;height:60px;border-radius:50%;background:#00eaff;color:black;font-size:26px;border:none;cursor:pointer;}
.aiWindow{position:fixed;bottom:90px;right:20px;width:320px;background:#111;padding:15px;border-radius:10px;display:none;z-index:200;}
canvas{background:#000;margin-top:15px;border-radius:10px;}
</style>
</head>
<body>

<header>🚀 UpgradedForce Ultimate Hub vImages</header>

<div class="topBanner" onclick="window.open('https://github.com/jackpaun/Dr-bugsteins-basemeaeaemtnte/tree/main/Assets','_blank')">
🎮 Check out "Dr Bugsteins Basement" - GitHub Assets
</div>

<nav>
<select id="themeSelect" onchange="changeTheme(this.value)">
<option value="dark" selected>Dark</option>
<option value="light">Light</option>
<option value="blue">Blue</option>
<option value="green">Green</option>
</select>
<button onclick="openSection('home')">Home</button>
<button onclick="openSection('anime')">Anime & Movies</button>
<button onclick="openSection('games')">Games</button>
<button onclick="openSection('travel')">Travel</button>
<button onclick="openSection('nature')">Nature</button>
<button onclick="openSection('math')">Math</button>
<button onclick="openSection('languages')">Languages</button>
<button onclick="openSection('coding')">Coding</button>
<button onclick="openSection('leaderboard')">Leaderboards</button>
<button onclick="openSection('apps')">Apps</button>
<button onclick="openSection('space')">Solar System</button>
<button onclick="openSection('discord')">Discord</button>
</nav>

<!-- HOME -->
<div id="home" class="section" style="display:block">
<h2>Welcome!</h2>
<input id="search" placeholder="Search anything">
<button onclick="searchWeb()">Search</button>
<div>
<h3>Recent Users</h3>
<ul id="recentList"></ul>
</div>
<img src="https://images.unsplash.com/photo-1581090700227-6c8f5e77e72e?auto=format&fit=crop&w=900&q=80">
</div>

<!-- ANIME -->
<div id="anime" class="section">
<h2>Anime & Movies</h2>
<div class="grid">
<div class="card" onclick="openSite('https://www.crunchyroll.com/')">
<img src="https://upload.wikimedia.org/wikipedia/commons/1/11/Crunchyroll_Logo.svg"><p>Crunchyroll</p>
</div>
<div class="card" onclick="openSite('https://www.funimation.com/')">
<img src="https://upload.wikimedia.org/wikipedia/en/7/70/Funimation_logo.png"><p>Funimation</p>
</div>
<div class="card" onclick="openSite('https://www.netflix.com/')">
<img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Netflix_2015_logo.svg"><p>Netflix</p>
</div>
</div>
</div>

<!-- GAMES -->
<div id="games" class="section">
<h2>Games</h2>
<div class="grid">
<div class="card" onclick="openSite('https://store.steampowered.com/')">
<img src="https://upload.wikimedia.org/wikipedia/commons/8/83/Steam_icon_logo.svg"><p>Steam</p>
</div>
<div class="card" onclick="openSite('https://www.epicgames.com/store/en-US/')">
<img src="https://upload.wikimedia.org/wikipedia/commons/3/31/Epic_Games_logo.svg"><p>Epic Games</p>
</div>
<div class="card" onclick="openSite('https://www.roblox.com/')">
<img src="https://upload.wikimedia.org/wikipedia/commons/1/14/Roblox_Logo_2022.svg"><p>Roblox</p>
</div>
</div>
</div>

<!-- TRAVEL -->
<div id="travel" class="section">
<h2>Travel</h2>
<div class="grid">
<div class="card"><img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=400&q=80"><p>Maldives</p></div>
<div class="card"><img src="https://images.unsplash.com/photo-1526772662000-3f88f10405ff?auto=format&fit=crop&w=400&q=80"><p>Paris</p></div>
<div class="card"><img src="https://images.unsplash.com/photo-1531177071289-49d0cbd02299?auto=format&fit=crop&w=400&q=80"><p>Tokyo</p></div>
</div>
</div>

<!-- NATURE -->
<div id="nature" class="section">
<h2>Nature</h2>
<div class="grid">
<div class="card"><img src="https://images.unsplash.com/photo-1501700493788-fa1a635c30d3?auto=format&fit=crop&w=400&q=80"><p>Tiger</p></div>
<div class="card"><img src="https://images.unsplash.com/photo-1470770841072-f978cf4d019e?auto=format&fit=crop&w=400&q=80"><p>Forest</p></div>
<div class="card"><img src="https://images.unsplash.com/photo-1470770903676-69b98201ea1c?auto=format&fit=crop&w=400&q=80"><p>Mountains</p></div>
</div>
</div>

<!-- MATH -->
<div id="math" class="section">
<h2>Math Quiz</h2>
<select id="mathLevel"><option value="easy">Easy</option><option value="medium">Medium</option></select>
<button onclick="startMath()">Start Quiz</button>
<div id="mathQuiz"></div>
<img src="https://images.unsplash.com/photo-1581090700227-6c8f5e77e72e?auto=format&fit=crop&w=400&q=80">
</div>

<!-- LANGUAGES -->
<div id="languages" class="section">
<h2>Language Quiz</h2>
<select id="langSelect"><option value="english">English</option><option value="swedish">Swedish</option></select>
<button onclick="startLang()">Start Quiz</button>
<div id="langQuiz"></div>
<img src="https://images.unsplash.com/photo-1600185363536-29e70f99b02d?auto=format&fit=crop&w=400&q=80">
</div>

<!-- CODING -->
<div id="coding" class="section">
<h2>Coding Quiz</h2>
<select id="codeLang"><option value="javascript">JavaScript</option><option value="python">Python</option></select>
<button onclick="startCoding()">Start Quiz</button>
<div id="codeQuiz"></div>
<img src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=400&q=80">
</div>

<!-- LEADERBOARDS -->
<div id="leaderboard" class="section">
<h2>Leaderboards</h2>
<ol id="mathLeaderboard"></ol>
<ol id="codingLeaderboard"></ol>
<ol id="gameLeaderboard"></ol>
<img src="https://images.unsplash.com/photo-1603791440384-56cd371ee9b7?auto=format&fit=crop&w=400&q=80">
</div>

<!-- APPS -->
<div id="apps" class="section">
<h2>Apps</h2>
<div class="grid">
<div class="card" onclick="openSite('https://www.vscode.dev/')"><img src="https://upload.wikimedia.org/wikipedia/commons/9/9a/Visual_Studio_Code_1.35_icon.svg"><p>VSCode</p></div>
<div class="card" onclick="openSite('https://replit.com/')"><img src="https://upload.wikimedia.org/wikipedia/commons/6/6e/Repl.it_logo.svg"><p>Replit</p></div>
</div>
</div>

<!-- SOLAR SYSTEM -->
<div id="space" class="section">
<h2>Solar System</h2>
<canvas id="solar" width="900" height="500"></canvas>
</div>

<!-- DISCORD -->
<div id="discord" class="section">
<h2>Join Our Discord</h2>
<a href="https://discord.gg/74VjTdbK" target="_blank"><img src="https://upload.wikimedia.org/wikipedia/commons/9/98/Discord_logo.svg" style="width:200px;"></a>
</div>

<!-- AI -->
<div class="aiWindow" id="aiWindow">
<textarea id="aiInput"></textarea>
<button onclick="aiAnswer()">Ask</button>
<div id="aiOutput"></div>
</div>
<button class="aiButton" onclick="toggleAI()">🤖</button>

<script>
// Section navigation
function openSection(id){document.querySelectorAll(".section").forEach(s=>s.style.display="none");document.getElementById(id).style.display="block";}
function openSite(url){window.open(url);}
function searchWeb(){let q=document.getElementById("search").value;window.open("https://google.com/search?q="+q);}
function toggleAI(){let w=document.getElementById("aiWindow");w.style.display=w.style.display=="block"?"none":"block";}
function aiAnswer(){document.getElementById("aiOutput").innerText="AI: Explore quizzes and fun content!";}
function changeTheme(t){if(t=='dark'){document.body.style.background='#070b18';document.body.style.color='white';}if(t=='light'){document.body.style.background='#eee';document.body.style.color='black';}if(t=='blue'){document.body.style.background='#0b1f40';document.body.style.color='white';}if(t=='green'){document.body.style.background='#06210d';document.body.style.color='white';}}

// Recent users
let recent=["Alice","Bob","Charlie"];
let list=document.getElementById("recentList");recent.forEach(u=>list.innerHTML+=`<li>${u} active</li>`);

// Math Quiz
let mathQ=[], mathIndex=0, mathScore=0;
function startMath(){mathQ=[];mathIndex=0;mathScore=0;for(let i=0;i<5;i++){let a=Math.floor(Math.random()*10);let b=Math.floor(Math.random()*10);mathQ.push({q:a+"+"+b,a:a+b});}showMath();}
function showMath(){if(mathIndex>=mathQ.length){document.getElementById("mathQuiz").innerText="Score: "+mathScore+"/"+mathQ.length;return;}let q=mathQ[mathIndex];document.getElementById("mathQuiz").innerHTML=q.q+" = <input id='mathAns'><button onclick='checkMath()'>Answer</button>";}
function checkMath(){let a=document.getElementById("mathAns").value;if(parseInt(a)==mathQ[mathIndex].a) mathScore++;mathIndex++;showMath();}

// Language Quiz
let langQ=[{q:"Hello",a:"English"},{q:"Hej",a:"Swedish"}], langIndex=0, langScore=0;
function startLang(){langIndex=0;langScore=0;showLang();}
function showLang(){if(langIndex>=langQ.length){document.getElementById("langQuiz").innerText="Score: "+langScore+"/"+langQ.length;return;}let q=langQ[langIndex];document.getElementById("langQuiz").innerHTML=q.q+" language? <input id='langAns'><button onclick='checkLang()'>Answer</button>";}
function checkLang(){let a=document.getElementById("langAns").value;if(a.toLowerCase()==langQ[langIndex].a.toLowerCase()) langScore++;langIndex++;showLang();}

// Coding Quiz
let codeQ=[], codeIndex=0, codeScore=0;
function startCoding(){codeIndex=0;codeScore=0;codeQ=[{q:"console.log('Hello') outputs?","a":"Hello"}];showCode();}
function showCode(){if(codeIndex>=codeQ.length){document.getElementById("codeQuiz").innerText="Score: "+codeScore+"/"+codeQ.length;return;}let q=codeQ[codeIndex];document.getElementById("codeQuiz").innerHTML=q.q+" <input id='codeAns'><button onclick='checkCode()'>Answer</button>";}
function checkCode(){let a=document.getElementById("codeAns").value;if(a==codeQ[codeIndex].a) codeScore++;codeIndex++;showCode();}

// Solar System
const c=document.getElementById("solar"), ctx=c.getContext("2d");let angle=0;
let planets=[{r:60,size:6,color:"gray"},{r:100,size:8,color:"orange"},{r:140,size:10,color:"blue"},{r:180,size:9,color:"red"},{r:240,size:16,color:"orange"}];
function draw(){ctx.clearRect(0,0,900,500);ctx.fillStyle="yellow";ctx.beginPath();ctx.arc(450,250,20,0,2*Math.PI);ctx.fill();planets.forEach((p,i)=>{let x=450+p.r*Math.cos(angle+i*0.6);let y=250+p.r*Math.sin(angle+i*0.6);ctx.fillStyle=p.color;ctx.beginPath();ctx.arc(x,y,p.size,0,2*Math.PI);ctx.fill();});angle+=0.01;requestAnimationFrame(draw);}
draw();
</script>

</body>
</html>
